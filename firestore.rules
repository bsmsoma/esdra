rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.admin == true;
    }
    
    // Produtos (existente)
    match /lojas/{lojaId}/products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Estoque (subcoleção)
      match /inventory/{size} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
    
    // Clientes
    match /lojas/{lojaId}/customers/{customerId} {
      allow read: if isOwner(customerId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(customerId);
      allow update: if isOwner(customerId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Carrinhos
    match /lojas/{lojaId}/carts/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }
    
    // Pedidos: only owner or admin can read; only owner can create order for themselves
    match /lojas/{lojaId}/orders/{orderId} {
      allow read: if isAdmin() || 
                    (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow create: if isAuthenticated() && 
                       request.resource.data.customerId == request.auth.uid;
      // Atualizações críticas (status, pagamento, total, itens) devem ser feitas no backend.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
} 